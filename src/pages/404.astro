---
import SEO from '../components/SEO/SEO.astro';
import '../public/css/index.css';
import '../public/css/hover.css';
import '../public/css/animations.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title="Page Not Found | Guido Gauna"
      description="The page you're looking for doesn't exist."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto+Condensed&family=Source+Sans+Pro:wght@300;400;600;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      .error-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: var(--spacing-xl);
        background-image: var(--gradient-hero);
      }

      .error-code {
        font-size: clamp(100px, 20vw, 200px);
        font-weight: 900;
        color: var(--color-primary);
        line-height: 1;
        margin-bottom: var(--spacing-md);
        text-shadow: 4px 4px 0 var(--color-border);
      }

      .error-title {
        font-size: var(--font-size-2xl);
        font-weight: 700;
        color: var(--color-text-heading);
        margin-bottom: var(--spacing-md);
      }

      .error-message {
        font-size: var(--font-size-lg);
        color: var(--color-text-secondary);
        max-width: 500px;
        margin-bottom: var(--spacing-xl);
      }

      .home-button {
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-md) var(--spacing-xl);
        background-color: var(--color-primary);
        color: var(--color-text-inverse);
        font-size: var(--font-size-lg);
        font-weight: 700;
        border: none;
        border-radius: var(--radius-lg);
        text-decoration: none;
        transition: transform var(--transition-fast), box-shadow var(--transition-fast);
      }

      .home-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(250, 207, 15, 0.4);
      }

      .home-button svg {
        width: 20px;
        height: 20px;
      }

      .illustration {
        margin-bottom: var(--spacing-xl);
      }

      .illustration svg {
        width: 200px;
        height: 200px;
        color: var(--color-text-secondary);
        opacity: 0.3;
      }
    </style>
  </head>
  <body>
    <main class="error-page">
      <div class="illustration">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <circle cx="12" cy="12" r="10" />
          <path d="M16 16s-1.5-2-4-2-4 2-4 2" />
          <line x1="9" y1="9" x2="9.01" y2="9" stroke-width="3" />
          <line x1="15" y1="9" x2="15.01" y2="9" stroke-width="3" />
        </svg>
      </div>
      <h1 class="error-code">404</h1>
      <h2 class="error-title">Page Not Found</h2>
      <p class="error-message">
        Oops! The page you're looking for seems to have wandered off.
        Let's get you back on track.
      </p>
      <a href="/" class="home-button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        Back to Home
      </a>
    </main>
  </body>
</html>
