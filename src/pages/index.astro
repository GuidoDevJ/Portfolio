---
// SEO Component
import SEO from "src/components/SEO/SEO.astro";

// App Component (with LanguageProvider)
import { App } from "src/components/App/App";

// GitHub data fetching (build-time)
import { fetchGitHubProjects } from "src/lib/github";
import { PROJECTS } from "src/constants/projects";

// LinkedIn data parsing (build-time)
import { loadLinkedInExperiences } from "src/lib/linkedin";
import { EXPERIENCES } from "src/constants/experience";

// Styles
import "../public/css/index.css";
import "../public/css/hover.css";
import "../public/css/animations.css";

const githubProjects = await fetchGitHubProjects();
const projects = githubProjects.length > 0 ? githubProjects : PROJECTS;

const linkedinExperiences = loadLinkedInExperiences();
const experiences = linkedinExperiences ?? EXPERIENCES;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@400;500;700&family=Source+Sans+Pro:wght@300;400;500;600;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />

    <!-- Theme & Language Script (prevent flash) -->
    <script is:inline>
      // Theme
      const theme = localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);

      // Language
      const lang = localStorage.getItem('language') ||
        (navigator.language.startsWith('es') ? 'es' : 'en');
      document.documentElement.setAttribute('lang', lang);
    </script>
  </head>

  <body>
    <App client:only="react" projects={projects} experiences={experiences} />
  </body>
</html>

<style>
  .header {
    width: 100%;
    height: auto;
  }

  .main {
    width: 100%;
    overflow-x: hidden;
  }
</style>
