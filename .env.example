# GitHub Personal Access Token
# Scopes necesarios: read:user (para pinned repos via GraphQL)
# Generá uno en: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Tu username de GitHub
GITHUB_USERNAME=GuidoDevJ

# Resend API Key — obtené la tuya en https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Email donde recibís los mensajes del portfolio
RECIPIENT_EMAIL=tu@email.com

# Chat assistant API (personal AI agent)
PUBLIC_CHAT_API_URL=http://localhost:8001
CHAT_API_KEY=your_api_key_here
